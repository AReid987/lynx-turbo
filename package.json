{
  "name": "@lynx/lynx-turbo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:lynx-agent": "turbo dev --filter=@lynx/lynx-agent",
    "dev:lynx-docs": "turbo dev --filter=@lynx/lynx-docs",
    "docker": "",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "cz": "czg" 
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git",
      "useEmoji": true
    }
  },
  "devDependencies": {
    "@turbo/gen": "^2.4.0",
    "commitizen": "^4.3.1",
    "cz-git": "^1.11.0",
    "czg": "^1.11.1",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^8.0.0",
    "prettier": "^3.4.2",
    "turbo": "^2.4.0",
    "typescript": "5.7.3"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@playwright/browser-chromium",
      "@vercel/speed-insights",
      "better-sqlite3",
      "core-js-pure",
      "esbuild",
      "sharp"
    ]
  }
}
